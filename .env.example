# Copy to .env and fill in. Loaded by config/settings.py via python-dotenv.
# Every variable here has a sensible default in settings.py — for local dev you
# can run with an empty .env. Set these explicitly in production (e.g. Railway).

# === Django core =============================================================

# Cryptographic signing key (sessions, CSRF, tokens). MUST be long, random, and
# secret in production. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# True for local dev. MUST be False in production (turns on security hardening).
DJANGO_DEBUG=True

# Hostnames Django will serve. Add your prod domain in production.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# === Database ================================================================
# Unset -> SQLite (local dev). Set -> Postgres (production).
# Railway sets this automatically when a Postgres service is attached
# (reference it there as ${{ Postgres.DATABASE_URL }}).
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# === CORS — which frontend origins may call this API from the browser ========
# The React app's origin(s). Used by django-cors-headers so the browser allows
# the SPA to read API responses. Add your deployed frontend origin in production.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Dev escape hatch: allow ALL origins. Keep False; never enable in production.
CORS_ALLOW_ALL_ORIGINS=False

# === Map / routing APIs (free) ===============================================
# OpenRouteService: free key at https://openrouteservice.org/dev/#/signup
# Leave ORS_API_KEY blank to fall back to the public OSRM demo + Nominatim.
ORS_API_KEY=
ORS_BASE_URL=https://api.openrouteservice.org
OSRM_BASE_URL=https://router.project-osrm.org

# Nominatim geocoding (OSM). Set a descriptive contact per their usage policy.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
GEOCODER_USER_AGENT=eld-trip-planner (your-email@example.com)

# Restrict geocoding to these ISO 3166-1 alpha-2 countries so users can only pick
# routable places (a US HOS trip can't start on another continent). Comma-separated;
# blank = worldwide. Widen to e.g. US,CA,MX for cross-border North American trips.
GEOCODE_COUNTRIES=US

# Trips are timed in the local zone of their current location (resolved from coords).
# This IANA zone is only the fallback when that lookup fails.
FALLBACK_TIMEZONE=America/Chicago

# === Production only (set on Railway; ignored when DJANGO_DEBUG=True) =========
# RAILWAY_PUBLIC_DOMAIN is injected by Railway automatically — do not set it; it
# is added to ALLOWED_HOSTS and CSRF_TRUSTED_ORIGINS for you.

# Origins trusted for cookie-authenticated writes (Django admin + DRF browsable
# API). Needs the scheme. Your Railway domain is added automatically.
# CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app

# HTTPS hardening (only applied when DJANGO_DEBUG=False):
# SECURE_SSL_REDIRECT=True              # default True in production
# SECURE_HSTS_SECONDS=31536000          # set once HTTPS is confirmed working
